# MongoDB connection string
MONGODB_URI=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# S3-compatible object storage (e.g. ParsPack). Generic S3 -> forcePathStyle + custom endpoint.
S3_ENDPOINT=
S3_REGION=default
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KEY_PREFIX=behanvape
# Public read base. getPublicUrl(key) = S3_PUBLIC_URL_BASE + key  (key already includes S3_KEY_PREFIX). Keep the trailing slash.
S3_PUBLIC_URL_BASE=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
# Must mirror VAPID_PUBLIC_KEY exactly (the browser needs it to subscribe).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
